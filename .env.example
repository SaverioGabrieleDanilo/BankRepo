# Copia questo file in .env (mai committato) e valorizza i segreti reali.

# Keycloak - client applicativo (Admin Console -> Clients -> banca-client -> Credentials)
KEYCLOAK_CLIENT_SECRET=

# Keycloak - utente admin usato dal Keycloak admin client
KEYCLOAK_ADMIN_PASSWORD=

# Postgres - password utente applicativo
DB_PASSWORD=

# --- Opzionali: hanno un default in application.properties, sovrascrivi solo se serve ---
# KEYCLOAK_ISSUER_URI=http://localhost:9090/realms/gestionale-banca
# KEYCLOAK_SERVER_URL=http://localhost:9090
# KEYCLOAK_CLIENT_ID=banca-client
# KEYCLOAK_ADMIN_USERNAME=admin
# DB_URL=jdbc:postgresql://localhost:5432/gestionale_banca
# DB_USERNAME=postgres
