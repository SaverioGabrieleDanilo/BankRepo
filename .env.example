# usati sia da application.properties sia da docker-compose.yml (stessa fonte)

# Client "banca-service" (service-account, permessi manage-users/manage-realm):
# valore di default gia' coerente con keycloak/realm-import/gestionale-banca-realm.json,
# importato in automatico da Keycloak al primo avvio del container (docker compose up -d,
# vedi command: start-dev --import-realm) - non serve piu' crearlo a mano in Admin Console.
# SOLO PER SVILUPPO LOCALE: se questo ambiente viene mai condiviso o esposto, genera un
# secret nuovo in Admin Console e sostituisci sia qui sia nel realm-import.
KEYCLOAK_SERVICE_CLIENT_SECRET=dev-only-banca-service-secret

DB_PASSWORD=

# Password del Postgres condiviso (app + Keycloak, un solo container/volume).
# ATTENZIONE: applicata solo alla PRIMA inizializzazione del volume postgres_data.
# Se il volume esiste gia' con una password diversa, cambiare questo valore non
# ha effetto: bisogna allineare POSTGRES_PASSWORD a quella con cui il volume e'
# stato creato, oppure ricreare il volume da zero (docker compose down -v).
POSTGRES_PASSWORD=root

# Opzionale: default = http://localhost:4200 (dev server Angular). In produzione
# impostare qui il/i dominio/i reali del frontend, separati da virgola se piu' di uno
# (es. https://app.miobanca.it). Nessun wildcard e' accettato: solo origin esatti.
CORS_ALLOWED_ORIGINS=

# Se true, crea in automatico all'avvio un utente ADMIN di bootstrap (username "admin",
# password "AdminBanca#2026") sia su Keycloak sia sul DB applicativo, solo se non esiste
# gia' un utente con quello username - elimina il passo manuale altrimenti necessario alla
# primissima installazione (vedi README, "Bootstrap del primo utente ADMIN").
# SOLO PER SVILUPPO LOCALE: lascia false (o non impostare la variabile) in qualunque
# ambiente condiviso o raggiungibile da altri, altrimenti chiunque conosce queste
# credenziali di default ottiene un account ADMIN.
BOOTSTRAP_DEFAULT_ADMIN=true
