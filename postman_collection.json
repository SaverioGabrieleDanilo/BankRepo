{
  "info": {
    "name": "Gestionale Banca",
    "description": "Collection completa degli endpoint REST di gestionale-banca. Il login applicativo (POST /api/auth/login) e' stato rimosso: il backend non gestisce piu' credenziali, il frontend usa Authorization Code + PKCE via keycloak-js. Per popolare {{token}} qui la richiesta 'Login' chiama Keycloak direttamente con un client dedicato al testing (vedi README, sezione 'Testare l'API a mano').",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8888" },
    { "key": "keycloakTokenUrl", "value": "http://localhost:9090/realms/gestionale-banca/protocol/openid-connect/token" },
    { "key": "testClientId", "value": "banca-cli" },
    { "key": "testClientSecret", "value": "" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "accountId", "value": "1" },
    { "key": "transactionId", "value": "1" }
  ],
  "item": [
    {
      "name": "Autenticazione",
      "item": [
        {
          "name": "Login (via Keycloak, client di test)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [ { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id", "value": "{{testClientId}}" },
                { "key": "client_secret", "value": "{{testClientSecret}}" },
                { "key": "username", "value": "mrossi" },
                { "key": "password", "value": "password123" }
              ]
            },
            "url": {
              "raw": "{{keycloakTokenUrl}}",
              "host": [ "{{keycloakTokenUrl}}" ]
            }
          }
        }
      ]
    },
    {
      "name": "Utenti",
      "item": [
        {
          "name": "Registra utente (pubblico)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"mrossi\",\n  \"password\": \"password123\",\n  \"firstName\": \"Mario\",\n  \"lastName\": \"Rossi\",\n  \"email\": \"mario.rossi@example.com\",\n  \"dateOfBirth\": \"1990-05-12\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/utenti/registra",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "utenti", "registra" ]
            }
          }
        },
        {
          "name": "Crea utente con ruolo (ADMIN)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"gverdi\",\n  \"password\": \"password123\",\n  \"firstName\": \"Giulia\",\n  \"lastName\": \"Verdi\",\n  \"email\": \"giulia.verdi@example.com\",\n  \"dateOfBirth\": \"1988-02-20\",\n  \"role\": \"EMPLOYEE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/utenti/admin/crea",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "utenti", "admin", "crea" ]
            }
          }
        },
        {
          "name": "Dettaglio utente (ADMIN)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/utenti/{{userId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "utenti", "{{userId}}" ]
            }
          }
        },
        {
          "name": "Elenco paginato utenti (ADMIN)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/utenti?page=0&size=10",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "utenti" ],
              "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "10" } ]
            }
          }
        },
        {
          "name": "Modifica utente (ADMIN o proprietario)",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuova.email@example.com\",\n  \"role\": \"EMPLOYEE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/utenti/{{userId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "utenti", "{{userId}}" ]
            }
          }
        },
        {
          "name": "Disattiva utente (ADMIN/EMPLOYEE)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/utenti/{{userId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "utenti", "{{userId}}" ]
            }
          }
        },
        {
          "name": "Cambia stato utente (ADMIN/EMPLOYEE)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stato\": \"SOSPESO\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/utenti/{{userId}}/status",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "utenti", "{{userId}}", "status" ]
            }
          }
        }
      ]
    },
    {
      "name": "Conti correnti",
      "item": [
        {
          "name": "Apertura conto (EMPLOYEE/CUSTOMER)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/conti/apertura",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "conti", "apertura" ]
            }
          }
        },
        {
          "name": "Approva/rifiuta apertura (EMPLOYEE/ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approva\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/conti/{{accountId}}/approve",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "conti", "{{accountId}}", "approve" ]
            }
          }
        },
        {
          "name": "Chiusura conto (CUSTOMER)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/conti/{{accountId}}/chiusura",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "conti", "{{accountId}}", "chiusura" ]
            }
          }
        },
        {
          "name": "Elenco conti (ADMIN)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/conti?page=0&size=10",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "conti" ],
              "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "10" } ]
            }
          }
        },
        {
          "name": "Consulta limiti conto (CUSTOMER)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/conti/{{accountId}}/limits",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "conti", "{{accountId}}", "limits" ]
            }
          }
        },
        {
          "name": "Imposta limiti conto (EMPLOYEE/ADMIN)",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dailyWithdrawalLimit\": 500.00,\n  \"singleTransactionLimit\": 1000.00,\n  \"monthlyTransferLimit\": 5000.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/conti/{{accountId}}/limits",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "conti", "{{accountId}}", "limits" ]
            }
          }
        }
      ]
    },
    {
      "name": "Transazioni",
      "item": [
        {
          "name": "Versamento (EMPLOYEE/CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"iban\": \"IT60X0000000000000000000001\",\n  \"amount\": 100.00,\n  \"description\": \"Versamento contanti\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/versamento",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "transactions", "versamento" ]
            }
          }
        },
        {
          "name": "Prelievo (EMPLOYEE/CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"iban\": \"IT60X0000000000000000000001\",\n  \"amount\": 50.00,\n  \"description\": \"Prelievo sportello\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/prelievo",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "transactions", "prelievo" ]
            }
          }
        },
        {
          "name": "Bonifico (CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceIban\": \"IT60X0000000000000000000001\",\n  \"targetIban\": \"IT60X0000000000000000000002\",\n  \"amount\": 100.00,\n  \"description\": \"Bonifico affitto\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/transfer",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "transactions", "transfer" ]
            }
          }
        },
        {
          "name": "Giroconto (CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceIban\": \"IT60X0000000000000000000001\",\n  \"targetIban\": \"IT60X0000000000000000000003\",\n  \"amount\": 200.00,\n  \"description\": \"Giroconto risparmio\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/giroconto",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "transactions", "giroconto" ]
            }
          }
        },
        {
          "name": "Dettaglio transazione (EMPLOYEE/ADMIN)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "transactions", "{{transactionId}}" ]
            }
          }
        }
      ]
    }
  ]
}
